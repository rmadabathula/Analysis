# ============================================================
# STEP 1: Run GO and KEGG enrichment for each gene list
# (input files contain Arabidopsis TAIR IDs, one per line,
#  obtained via BLASTP of rootstock genes against TAIR10)
# ============================================================

run_enrichment <- function(gene_file, label) {
  genes <- readLines(gene_file)
  genes <- gsub("\\.\\d+$", "", genes)  # strip .1/.2 transcript suffix
  
  cat("\n=== ", label, " (n=", length(genes), " genes) ===\n")
  
  go_result <- enrichGO(
    gene = genes,
    OrgDb = org.At.tair.db,
    keyType = "TAIR",
    ont = "ALL",
    pAdjustMethod = "BH",
    pvalueCutoff = 0.05,
    qvalueCutoff = 0.2
  )
  
  go_df <- as.data.frame(go_result)
  cat("GO significant terms:", nrow(go_df), "\n")
  if (nrow(go_df) > 0) {
    print(go_df[, c("ONTOLOGY", "Description", "GeneRatio", "p.adjust")])
  }
  
  entrez_ids <- bitr(genes, fromType = "TAIR", toType = "ENTREZID", OrgDb = org.At.tair.db)
  
  kegg_result <- enrichKEGG(
    gene = entrez_ids$ENTREZID,
    organism = "ath",
    pAdjustMethod = "BH",
    pvalueCutoff = 0.05
  )
  
  kegg_df <- as.data.frame(kegg_result)
  cat("KEGG significant terms:", nrow(kegg_df), "\n")
  if (nrow(kegg_df) > 0) {
    print(kegg_df[, c("Description", "GeneRatio", "p.adjust")])
  }
  
  return(list(go = go_result, kegg = kegg_result))
}

# ---- Run for all six gene lists ----
