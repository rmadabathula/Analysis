# ----------------------------------------------------------------
# PART C: BUILD MASTER + TOP-10 TABLES
# ----------------------------------------------------------------
python3 << 'EOF'
import csv

ortholog_info = {}
with open('SNP_ROOTSTOCK/ortholog_mapping/ROOTSTOCK_ortholog_pairs.csv') as f:
    next(f)
    for line in f:
        parts = line.strip().split(',')
        ortholog_info[parts[0]] = (parts[1], parts[2])

def aggregate_snp_data(validated_tsv):
    gene_data = {}
    with open(validated_tsv) as f:
        next(f)
        for line in f:
            parts = line.strip().split('\t')
            gene = parts[0]
            r1, r2, r3 = int(parts[5]), int(parts[6]), int(parts[7])
            if gene not in gene_data:
                gene_data[gene] = {'positions': 0, 'r1': 0, 'r2': 0, 'r3': 0, 'reps_2plus': 0}
            gene_data[gene]['positions'] += 1
            gene_data[gene]['r1'] += r1
            gene_data[gene]['r2'] += r2
            gene_data[gene]['r3'] += r3
            if sum([r1 > 0, r2 > 0, r3 > 0]) >= 2:
                gene_data[gene]['reps_2plus'] += 1
    return gene_data

def build_master_table(all_genes_file, snp_data, out_file):
    all_genes = [line.strip() for line in open(all_genes_file)]
    with open(out_file, 'w', newline='') as out:
        writer = csv.writer(out, delimiter='\t')
        writer.writerow(['Gene_ID','WM_Ortholog','BLAST_Percent_Identity',
                          'SNP_validated_positions','Positions_in_2plus_reps',
                          'Rep1_reads','Rep2_reads','Rep3_reads','Confidence'])
        for gene in all_genes:
            wm_gene, pident = ortholog_info.get(gene, ('NA','NA'))
            if gene in snp_data:
                d = snp_data[gene]
                if d['reps_2plus'] >= 3: conf = 'High (multi-position, replicate-consistent)'
                elif d['reps_2plus'] >= 1: conf = 'Medium-High (replicate-consistent SNP support)'
                elif d['positions'] >= 5: conf = 'Medium (multiple SNP positions, single-rep)'
                else: conf = 'Low (single/few SNP position, single-rep)'
                writer.writerow([gene, wm_gene, pident, d['positions'], d['reps_2plus'],
                                  d['r1'], d['r2'], d['r3'], conf])
            else:
                writer.writerow([gene, wm_gene, pident, 0,0,0,0,0,'No SNP evidence'])

def print_top10(master_file, label):
    print(f"\n=== TOP 10 - {label} ===")
    rows = []
    with open(master_file) as f:
        reader = csv.reader(f, delimiter='\t')
        next(reader)
        for row in reader:
            gene, wm_gene, pident, positions, reps_2plus, r1, r2, r3, confidence = row
            if int(positions) > 0:
                rows.append((gene, wm_gene, pident, int(positions), reps_2plus, confidence))
    rows.sort(key=lambda x: -x[3])
    for i, r in enumerate(rows[:10], 1):
        print(f"{i:<5}{r[0]:<18}{r[1]:<16}{r[2]:<8}{r[3]:<10}{r[4]:<8}{r[5]}")
    print(f"\nTotal genes with SNP support: {len(rows)}")

control_snp_data = aggregate_snp_data('SNP_ROOTSTOCK/SNP_analysis_output/control_SNP_final_validated.tsv')
build_master_table('results_v2_condition_matched/ROOTSTOCK_mobile_control_TRUE_FINAL.genes',
                    control_snp_data, 'SNP_ROOTSTOCK/final_tables/ROOTSTOCK_Control_SNP_master_table.tsv')

wf_snp_data = aggregate_snp_data('SNP_ROOTSTOCK/SNP_analysis_output/whitefly_SNP_final_validated.tsv')
build_master_table('results_v2_condition_matched/ROOTSTOCK_mobile_WF_TRUE_FINAL.genes',
                    wf_snp_data, 'SNP_ROOTSTOCK/final_tables/ROOTSTOCK_WF_SNP_master_table.tsv')

print_top10('SNP_ROOTSTOCK/final_tables/ROOTSTOCK_Control_SNP_master_table.tsv', 'ROOTSTOCK Control')
print_top10('SNP_ROOTSTOCK/final_tables/ROOTSTOCK_WF_SNP_master_table.tsv', 'ROOTSTOCK WF')
EOF
