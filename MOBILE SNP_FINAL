best_hits = {}
with open('SNP_ROOTSTOCK/ortholog_mapping/ROOTSTOCK_vs_WCG_blast_results.tsv') as f:
    for line in f:
        parts = line.strip().split('\t')
        gene_id = parts[0].split('.')[0]
