with open('SNP_ROOTSTOCK/ortholog_mapping/ROOTSTOCK_ortholog_pairs.csv', 'w') as out:
    out.write("ROOTSTOCK_gene,WM_ortholog,percent_identity,bitscore\n")
    for gene_id in sorted(all_genes):
        if gene_id in best_hits:
            wm_gene, pident, bitscore = best_hits[gene_id]
            out.write(f"{gene_id},{wm_gene},{pident},{bitscore}\n")
        else:
            out.write(f"{gene_id},NO_ORTHOLOG_FOUND,NA,NA\n")

for cond, fname, outname in [
