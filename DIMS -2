# ============================================================
# STEP 5: Save Excel function
# ============================================================
save_excel <- function(data_to_save, file_path, sheet_title, 
                       highlight_type = FALSE) {
  
  wb <- createWorkbook()
  addWorksheet(wb, "Sheet1")
  
  writeData(wb, "Sheet1",
            data.frame(sheet_title),
            startRow = 1, colNames = FALSE)
  
  writeData(wb, "Sheet1", data_to_save, startRow = 2)
  
  # Header style
  addStyle(wb, "Sheet1",
           createStyle(fgFill = "#1F4E79", fontColour = "#FFFFFF",
                       textDecoration = "bold", halign = "center"),
           rows = 2, cols = 1:ncol(data_to_save), gridExpand = TRUE)
  
  if (highlight_type & "Type" %in% colnames(data_to_save)) {
    
    up_rows <- which(data_to_save$Type == "up") + 2
    if (length(up_rows) > 0) {
      addStyle(wb, "Sheet1",
               createStyle(fgFill = "#FFE0E0", halign = "center"),
               rows = up_rows,
               cols = 1:ncol(data_to_save),
               gridExpand = TRUE)
    }
    
    down_rows <- which(data_to_save$Type == "down") + 2
    if (length(down_rows) > 0) {
      addStyle(wb, "Sheet1",
               createStyle(fgFill = "#E0E8FF", halign = "center"),
               rows = down_rows,
               cols = 1:ncol(data_to_save),
               gridExpand = TRUE)
    }
  }
  
  setColWidths(wb, "Sheet1", cols = 1, widths = 28)
  setColWidths(wb, "Sheet1", cols = 2:ncol(data_to_save), widths = 14)
  
  saveWorkbook(wb, file_path, overwrite = TRUE)
  cat("Saved:", file_path, "\n")
}

