SS_cols   <- c("SS_1",   "SS_2",   "SS_3")
CSB_cols  <- c("CSB_1",  "CSB_2",  "CSB_3")
LG3_cols  <- c("LG3_1",  "LG3_2",  "LG3_3")
MM30_cols <- c("MM30_1", "MM30_2", "MM30_3")

# ============================================================
# STEP 3: Main function
# ============================================================
calculate_DIMs <- function(data, group1_cols, group2_cols, 
                           group2_name, vip_file_path) {
  
  cat("\n==============================\n")
  cat("Running:", group2_name, "vs SS\n")
  cat("==============================\n")
  
  mat <- data + 0.0001
  
  # Read VIP scores
  vip_data   <- read.csv(vip_file_path, row.names = 1, header = TRUE)
  vip_scores <- vip_data[, 1]
  names(vip_scores) <- rownames(vip_data)
  cat("VIP scores loaded for", length(vip_scores), "metabolites\n")
  
  # Calculate stats
  results <- data.frame()
  pvalues <- c()
  
  for (metab in rownames(data)) {
    
    g1 <- as.numeric(mat[metab, group1_cols])
    g2 <- as.numeric(mat[metab, group2_cols])
    
    fold_change <- mean(g2) / mean(g1)
    log2fc      <- log2(fold_change)
    
    # var.equal = TRUE makes R match Python's t-test
    pvalue  <- tryCatch(
      t.test(g1, g2, var.equal = TRUE)$p.value, 
      error = function(e) NA)
    
    pvalues  <- c(pvalues, pvalue)
    vip      <- as.numeric(vip_scores[metab])
    direction <- ifelse(log2fc > 0, "up", "down")
    
    results <- rbind(results, data.frame(
      Metabolite  = metab,
      VIP         = round(vip, 6),
      P_value     = round(pvalue, 6),
      FDR         = NA,
      Log2FC      = round(log2fc, 6),
      FoldChange  = round(fold_change, 6),
      Type        = direction,
      stringsAsFactors = FALSE
    ))
  }
  
  # FDR calculation
  results$FDR <- round(p.adjust(pvalues, method = "BH"), 6)
  
  # Filter DIMs
  dims <- results[
    !is.na(results$VIP)     & results$VIP > 1 &
      !is.na(results$P_value) & results$P_value < 0.05 &
      (results$Log2FC >= 1 | results$Log2FC <= -1), ]
  
  cat("Total DIMs:", nrow(dims),
      "| Up:", sum(dims$Type == "up"),
      "| Down:", sum(dims$Type == "down"), "\n")
  
  return(list(all = results, dims = dims))
}

