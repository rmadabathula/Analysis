  Kinase       = list(file = "Kinase_FULL_values_FINAL.csv",       height_per_gene = 0.08),
  Redox        = list(file = "Redox_FULL_values_FINAL.csv",        height_per_gene = 0.20),
  Metabolite   = list(file = "Metabolite_FULL_values_FINAL.csv",   height_per_gene = 0.20),
  CellWall     = list(file = "CellWall_FULL_values_FINAL.csv",     height_per_gene = 0.10)
)

color_palette <- colorRampPalette(c("green", "black", "red"))(100)
timestamp <- format(Sys.time(), "%Y%m%d_%H%M%S")

# ============================================================
# MAIN LOOP - processes every category automatically
# ============================================================

for (cat_name in names(categories)) {
  
  cfg <- categories[[cat_name]]
  
  if (!file.exists(cfg$file)) {
    cat("SKIPPING", cat_name, "- file not found:", cfg$file, "\n")
    next
  }
  
  cat("\n=== Processing category:", cat_name, "===\n")
  
  df <- read.csv(cfg$file, stringsAsFactors = FALSE)
  
  # Row labels: GeneID:Symbol (or GeneID:AT_ID if no symbol available)
  df$Label <- ifelse(
    !is.na(df$SYM) & trimws(df$SYM) != "",
    paste0(df$GeneID, ":", trimws(sub(",.*", "", df$SYM))),
    paste0(df$GeneID, ":", df$ARA_ID)
  )
  rownames(df) <- df$Label
  
  # Restore "/" in comparison column names (R converts "/" to "." on CSV read)
  colnames(df) <- gsub("\\.", "/", colnames(df))
  
  mat_full <- as.matrix(df[, comparison_cols])
  
  # Strict subset: |log2FC| >= 2 in at least one comparison
  strict_rows <- apply(mat_full, 1, function(x) any(abs(x) >= 2, na.rm = TRUE))
  mat_strict <- mat_full[strict_rows, , drop = FALSE]
  
  cat(cat_name, "- Full (|log2FC|>=1):", nrow(mat_full),
      "| Strict (|log2FC|>=2):", nrow(mat_strict), "\n")
  
  h_full   <- max(4, nrow(mat_full)   * cfg$height_per_gene)
  h_strict <- max(4, nrow(mat_strict) * cfg$height_per_gene * 1.5)
  
  # ---- Plot 1: Full set, clustered ----
  pheatmap(mat_full, color = color_palette, breaks = seq(-3.5, 3.5, length.out = 101),
    cluster_rows = TRUE, cluster_cols = TRUE, clustering_method = "complete",
    fontsize_row = 6, fontsize_col = 10, border_color = NA,
    main = paste0(cat_name, " |log2FC|>=1 (Clustered, n=", nrow(mat_full), ")"),
    filename = paste0(cat_name, "_FC1_CLUSTERED_", timestamp, ".png"),
    width = 8, height = h_full)
  
  # ---- Plot 2: Full set, fixed order ----
  pheatmap(mat_full, color = color_palette, breaks = seq(-3.5, 3.5, length.out = 101),
    cluster_rows = FALSE, cluster_cols = FALSE,
    fontsize_row = 6, fontsize_col = 10, border_color = NA,
    main = paste0(cat_name, " |log2FC|>=1 (Fixed Order, n=", nrow(mat_full), ")"),
    filename = paste0(cat_name, "_FC1_FIXED_ORDER_", timestamp, ".png"),
    width = 8, height = h_full)
  
  # ---- Plot 3 & 4: Strict subset (only if enough genes remain) ----
  if (nrow(mat_strict) >= 2) {
    pheatmap(mat_strict, color = color_palette, breaks = seq(-3.5, 3.5, length.out = 101),
      cluster_rows = TRUE, cluster_cols = TRUE, clustering_method = "complete",
      fontsize_row = 7, fontsize_col = 10, border_color = NA,
      main = paste0(cat_name, " |log2FC|>=2 (Clustered, n=", nrow(mat_strict), ")"),
      filename = paste0(cat_name, "_FC2_CLUSTERED_", timestamp, ".png"),
      width = 8, height = h_strict)
    
    pheatmap(mat_strict, color = color_palette, breaks = seq(-3.5, 3.5, length.out = 101),
      cluster_rows = FALSE, cluster_cols = FALSE,
      fontsize_row = 7, fontsize_col = 10, border_color = NA,
      main = paste0(cat_name, " |log2FC|>=2 (Fixed Order, n=", nrow(mat_strict), ")"),
      filename = paste0(cat_name, "_FC2_FIXED_ORDER_", timestamp, ".png"),
      width = 8, height = h_strict)
  } else {
    cat("  Skipping FC>=2 plots for", cat_name, "- too few genes (", nrow(mat_strict), ")\n")
  }
}

cat("\n=== ALL CATEGORY HEATMAPS COMPLETE ===\n")
cat("Check your working directory for PNG files timestamped:", timestamp, "\n")


























