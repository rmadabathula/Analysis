comparison_cols <- c("UGWF/UG", "SGWF/SG", "CSBWF/CSB", "LG3WF/LG3", "MM30WF/MM30")

# Each category's input file + plot-height scaling factor (adjust if a
# plot looks too cramped or too stretched for its gene count)
categories <- list(
  Phytohormone = list(file = "phytohormone_FULL_values_FINAL.csv", height_per_gene = 0.10),
  Calcium      = list(file = "calcium_FULL_values_FINAL.csv",      height_per_gene = 0.20),
