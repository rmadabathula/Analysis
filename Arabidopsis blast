sed 's/^/^/; s/$/\\./' missing_gene_ids.txt > missing_patterns.txt
seqkit grep -r -f missing_patterns.txt WCG_pep_v2.5.fa -o missing_proteins.fa

# Relaxed BLAST (e-value 1e-3 instead of 1e-5)
blastp -query missing_proteins.fa \
       -db tair10_db \
       -outfmt "6 qseqid sseqid pident length evalue bitscore stitle" \
       -evalue 1e-3 \
       -max_target_seqs 1 \
       -num_threads 8 \
       -out missing_recovered_hits.tsv
