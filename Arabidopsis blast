Step 1 — Install BLAST+
bashsudo apt update
sudo apt install ncbi-blast+ -y
blastp -version
Step 2 — Download TAIR10 Arabidopsis protein file (manual browser download required)
wget/curl directly gets blocked (403 Forbidden), so this has to be done manually:

Go to: https://www.arabidopsis.org/download/list?dir=Genes%2FTAIR10_genome_release%2FTAIR10_blastsets
Find Ath_AGI_LOCUS_TAIR10_Aug2012 → click the text download link (NOT the ISOFORM_MODEL version)
Move it into your working folder and rename:

bashmv ~/Downloads/TAIR10_pep_20101214_updated "/home/karthik/New folder/TAIR10_pep.fasta"
cd "/home/karthik/New folder"

# Verify it downloaded correctly (should NOT be HTML)
ls -lh TAIR10_pep.fasta
grep -c ">" TAIR10_pep.fasta
head -2 TAIR10_pep.fasta
Step 3 — Build the BLAST database (one-time step)
bashmakeblastdb -in TAIR10_pep.fasta -dbtype prot -out tair10_db
Step 4 — Run BLAST: your watermelon proteome against TAIR10
bashblastp -query WCG_pep_v2.5.fa \
       -db tair10_db \
       -outfmt "6 qseqid sseqid pident length evalue bitscore stitle" \
       -evalue 1e-5 \
       -max_target_seqs 1 \
       -num_threads 8 \
       -out watermelon_TAIR10_hits.tsv

wc -l watermelon_TAIR10_hits.tsv
Step 5 — Deduplicate to one best hit per gene
bashpython3 << 'EOF'
import pandas as pd

cols = ['watermelon_gene', 'arabidopsis_hit', 'pct_identity', 'aln_length', 'evalue', 'bit_score', 'stitle']
df = pd.read_csv('watermelon_TAIR10_hits.tsv', sep='\t', header=None, names=cols)

print(f"Raw rows: {len(df)}")
print(f"Unique genes: {df['watermelon_gene'].nunique()}")

df['evalue'] = pd.to_numeric(df['evalue'], errors='coerce')
df_best = df.sort_values('evalue').drop_duplicates(subset='watermelon_gene', keep='first')

print(f"After deduplication: {len(df_best)}")
df_best.to_csv('watermelon_TAIR10_best_hits.tsv', sep='\t', index=False)
print("Saved: watermelon_TAIR10_best_hits.tsv")
EOF
