import os

# Read CSB mobile gene IDs
mobile_genes = []
with open('/home/meghana/Karthik/Normalized_counts_mobile/C_mobile_final.genes') as f:
    for line in f:
        gene = line.strip()
        if gene:
            mobile_genes.append(gene)

print(f"CSB mobile genes loaded: {len(mobile_genes)}")

# Read count files for each sample
samples = ['C1', 'C2', 'C3', 'S1', 'S2', 'S3']
counts = {gene: {s: 0 for s in samples} for gene in mobile_genes}

for sample in samples:
    filepath = f'/home/meghana/Karthik/counts_CA/{sample}.gene_readcounts.tsv'
    if os.path.exists(filepath):
        with open(filepath) as f:
            for line in f:
                parts = line.strip().split('\t')
                if len(parts) >= 2:
                    gene = parts[0]
                    count = parts[1]
                    if gene in counts:
                        counts[gene][sample] = count
        print(f"Loaded: {sample}")
    else:
        print(f"WARNING: {filepath} not found!")

# Write count matrix
outfile = '/home/meghana/Karthik/Normalized_counts_mobile/CSB_mobile_counts.csv'
with open(outfile, 'w') as f:
    f.write('Gene,' + ','.join(samples) + '\n')
    for gene in mobile_genes:
        row = [gene] + [str(counts[gene][s]) for s in samples]
        f.write(','.join(row) + '\n')

print(f"\n✅ CSB count matrix saved!")
print(f"File: {outfile}")
print(f"Genes: {len(mobile_genes)}")
print(f"Samples: {samples}")
