# Get Normalized Counts from DESeq2 for genes
# Ramya - West Virginia State University
# ============================================================

library(DESeq2)

# ============================================================
# STEP 1: Load raw count table
# ============================================================
counts <- read.csv(
  "C:/Users/Student/Downloads/Karthik/Correlation/Wmfruit.csv",
  row.names = 1,
  header = TRUE,
  check.names = FALSE
)

cat("Genes:", nrow(counts), "\n")
cat("Samples:", ncol(counts), "\n")
cat("Sample names:", colnames(counts), "\n")

# ============================================================
# STEP 2: Make sure counts are integers
# ============================================================
counts <- round(counts)
counts <- as.matrix(counts)

# ============================================================
# STEP 3: Create sample information table
# SG = Self Graft (your control group)
# ============================================================
sample_info <- data.frame(
  row.names = colnames(counts),
  condition = c("CSB",  "CSB",  "CSB",
                "LG3",  "LG3",  "LG3",
                "MM30", "MM30", "MM30",
                "SG",   "SG",   "SG")
)

cat("\nSample information:\n")
print(sample_info)

# ============================================================
# STEP 4: Create DESeq2 object
# ============================================================
dds <- DESeqDataSetFromMatrix(
  countData = counts,
  colData   = sample_info,
  design    = ~ condition
)

# ============================================================
# STEP 5: Run normalization
# ============================================================
cat("\nRunning DESeq2 normalization...\n")
dds <- estimateSizeFactors(dds)

cat("\nSize factors:\n")
print(sizeFactors(dds))

# ============================================================
# STEP 6: Extract normalized counts
# ============================================================
normalized_counts <- counts(dds, normalized = TRUE)

cat("\nDimensions:", dim(normalized_counts), "\n")
cat("First few rows:\n")
print(head(normalized_counts))

# ============================================================
# STEP 7: Save normalized counts
# ============================================================
write.csv(
  normalized_counts,
  "C:/Users/Student/Downloads/Karthik/Correlation/normalized_counts.csv"
)

cat("\n✅ Normalized counts saved!\n")
cat("File: normalized_counts.csv in Correlation folder!\n")







